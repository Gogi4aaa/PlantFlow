{
    "name": "plantflow-server",
    "version": "1.0.0",
    "description": "REST API server for PlantFlow with MQTT integration",
    "main": "function.js",
    "type": "module",
    "scripts": {
        "start": "node src/index.js",
        "dev": "node --watch src/index.js",
        "deploy": "gcloud functions deploy plantflow-api --gen2 --runtime nodejs20 --region europe-west3 --source . --entry-point plantflow --trigger-http --allow-unauthenticated --memory 512MB --timeout 60s --env-vars-file .env.yaml",
        "postinstall": "prisma generate",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "prisma": {
        "seed": "node prisma/seed.js"
    },
    "keywords": [
        "mqtt",
        "iot",
        "plant-monitoring",
        "esp32",
        "rest-api"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@google-cloud/functions-framework": "^3.5.1",
        "@prisma/client": "^5.22.0",
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "joi": "^17.11.0",
        "jsonwebtoken": "^9.0.3",
        "morgan": "^1.10.0",
        "mqtt": "^5.15.0",
        "socket.io": "^4.8.3"
    },
    "devDependencies": {
        "prisma": "^5.22.0"
    }
}
